[Unit]
Description=MAINT SUPER — Maintenance & Calibration
After=network.target

[Service]
User=www-data
WorkingDirectory=/opt/maint-super
EnvironmentFile=/opt/maint-super/.env
ExecStart=/opt/maint-super/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
